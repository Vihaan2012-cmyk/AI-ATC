# --- LLM provider (local / downloadable models only) ---
# LLM_PROVIDER: ollama | openai-compatible
#   ollama            -> local Ollama (default)
#   openai-compatible -> any local OpenAI-compatible server:
#                        LM Studio, llama.cpp, Jan, LocalAI, KoboldCpp, oobabooga, vLLM, GPT4All...
LLM_PROVIDER=ollama
# For openai-compatible servers, e.g. http://localhost:1234/v1 (LM Studio)
LLM_BASE_URL=
# Usually blank for local servers (some accept any token)
LLM_API_KEY=
# Model id; blank falls back to OLLAMA_MODEL (ollama) or the loaded local model
LLM_MODEL=
# Compute device for the local LLM: auto | gpu | cpu
LLM_DEVICE=auto

# --- Ollama (used when LLM_PROVIDER=ollama) ---
OLLAMA_HOST=http://127.0.0.1:11434
# Light, fast, ATC-tuned model (recommended). Use qwen2.5:14b for a bigger general model.
OLLAMA_MODEL=myaimodels/atc-nlu

# --- Flight plan (SimBrief) ---
# Use your SimBrief username OR numeric Pilot ID (the ID is used first if set). Empty -> sample.
SIMBRIEF_USERNAME=
SIMBRIEF_USERID=
# Hoppie ACARS logon code (optional)
HOPPIE_LOGON=

# --- Brain comms server (the in-sim widget connects here) ---
WS_PORT=8742

# --- Auto-tune COM1 over SimConnect on handoff ---
# swap    = set standby AND flip it active (hands-free)   [default]
# standby = set standby only; you flip it active yourself (more realistic)
# off     = never touch your radio
AUTO_TUNE_COM=swap

# --- Realism ---
# Readback strictness: relaxed | normal | strict
ATC_STRICTNESS=normal
# Ambient AI radio chatter on frequency: off | low | medium | high
ATC_CHATTER=low

# --- Navdata sources (ordered fallback chain; first with data wins) ---
# sim  = MSFS default navdata via SimConnect (real freqs/runways; needs the sim)
# dfd  = Navigraph DFD SQLite at NAVDATA_PATH (or an aircraft's DFD nav DB)
# mock = tiny built-in placeholder set (offline last resort)
NAVDATA_SOURCES=sim,mock
# Path to a DFD .s3db if you use the 'dfd' source (Navigraph or aircraft nav DB; never committed)
NAVDATA_PATH=./navdata/cycle.s3db

# --- Facility cache (SimConnect airport data persisted to disk) ---
FACILITY_CACHE_DIR=./cache/facilities
FACILITY_CACHE_MAX_BYTES=17179869184
FACILITY_CACHE_TTL_DAYS=28
