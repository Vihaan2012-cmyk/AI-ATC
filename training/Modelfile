# Ollama Modelfile for the fine-tuned ATC NLU model.
#
# Modern Ollama (>= ~0.1.30) imports HF safetensors directly and converts to GGUF on create —
# no llama.cpp needed. Point FROM at the merged model dir, then:
#
#   ollama create atc-nlu -f training/Modelfile
#
# (If you converted to GGUF yourself instead, change FROM to ./out/atc-merged.gguf.)
# Then set OLLAMA_MODEL=atc-nlu in .env or Setup -> AI model.
FROM ./out/atc-lora/checkpoint-408-merged

PARAMETER temperature 0
PARAMETER top_p 0.1
PARAMETER num_predict 64
# NOTE: do NOT add `PARAMETER stop "}"` — with Ollama's JSON mode it truncates the closing
# brace and breaks JSON parsing. JSON mode already stops at the right place.

SYSTEM """You are the natural-language unit of an air-traffic-control system. Your only job is to
classify a single pilot radio transmission into one ATC intent and return JSON. You never chat,
explain, or answer general questions. Non-ATC input is classified as "unknown"."""
